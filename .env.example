# ============================================
# Camarote Eventos — variáveis de ambiente
# Copie este arquivo como `.env.local` para dev
# Configure as mesmas no painel da Vercel para produção
# ============================================

# === Supabase (DB + Auth + Storage) — Fase 0/1 ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Mercado Pago (gateway de pagamento) — Fase 1 ===
# Provedor pode ser trocado por AbacatePay ou Pagar.me na implementação
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# === Resend (email transacional + envio do ingresso) — Fase 1 ===
RESEND_API_KEY=

# === Assinatura de QR Code do ingresso — Fase 1 ===
# Gerar com: openssl rand -hex 32
TICKET_HMAC_SECRET=

# === Sentry (observabilidade) — Fase 4 ===
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
